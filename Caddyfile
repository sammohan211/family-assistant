# Reverse proxy for the Family Assistant app.
# CADDY_TLS values:
#   internal       -> use Caddy's internal CA (home / Tailscale / LAN)
#   <email>        -> use Let's Encrypt with this contact email (cloud)
{$APP_HOSTNAME} {
    tls {$CADDY_TLS}

    encode gzip

    # family-app is the pinned container_name in compose.cloud.yml. Don't use
    # the bare service name "app": Caddy also sits on the shared caddy_net,
    # where tenant apps can expose an "app" alias too, and Docker DNS may
    # resolve the bare name to a tenant instead of this app.
    reverse_proxy family-app:8000

    log {
        output stdout
        format json
    }
}

# Tenant site blocks, one file per app (see PRD_AND_ROADMAP.md §17.10).
# Tenant-owned: each app's repo is the source of truth for its .caddy file.
import sites/*.caddy
