# Copy to .env (or .env.home / .env.cloud) and fill in values.
# Never commit a populated .env file. .gitignore already excludes them.
#
# Hostnames below assume Docker Compose (services on the internal network).
# For local dev WITHOUT Docker, replace `postgres` with `localhost`.

# --- Database ---
POSTGRES_PASSWORD=CHANGE_ME
# Use the same password as POSTGRES_PASSWORD above.
DATABASE_URL=postgresql+psycopg://family_assistant:CHANGE_ME@postgres:5432/family_assistant

# --- Sessions ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SESSION_SECRET=CHANGE_ME

# --- Pre-seeded user credentials (PRD Section 10.1) ---
# Generate an Argon2id hash with (from inside the running app container):
#   docker compose exec app python -c "from argon2 import PasswordHasher; print(PasswordHasher().hash('your-password'))"
# IMPORTANT: the hash contains `$` characters. Docker Compose interprets a
# single `$` as a variable reference, so you MUST double every `$` here.
# Example: a hash printed as `$argon2id$v=19$m=...$salt$hash` must be stored as
#   USER1_PASSWORD_HASH=$$argon2id$$v=19$$m=...$$salt$$hash
USER1_EMAIL=
USER1_PASSWORD_HASH=
USER1_NAME=
USER2_EMAIL=
USER2_PASSWORD_HASH=
USER2_NAME=

# --- LLM provider selection ---
# Only "openrouter" (cloud OpenAI-compatible API) is supported.
# The offline mock (USE_MOCK_LLM below) overrides this regardless of value.
LLM_PROVIDER=openrouter

# --- OpenRouter (cloud LLM) ---
# Get a key at https://openrouter.ai/keys. Prompts leave your network to the
# chosen provider; pick a model/provider with a no-retention policy for
# household data.
OPENROUTER_API_KEY=
# Cheap, current, reliable at JSON `response_format` (what the assistant needs).
# Verify it's still listed — providers retire model snapshots, which surfaces as
# a 404 from /chat/completions. Browse models at https://openrouter.ai/models.
OPENROUTER_MODEL=google/gemini-2.5-flash-lite
# Optional app-attribution headers for OpenRouter's leaderboard (safe to skip).
OPENROUTER_APP_URL=
OPENROUTER_APP_TITLE=

# Set to `true` to swap the live LLM client for an offline keyword-driven
# mock. Useful for UI dev on a no-GPU machine and for demos. The mock has
# intentional failure modes triggered by keywords ("blank", "ghost", "bulk",
# "allergy", "crash", etc.) — see src/family_assistant/ai_gateway/llm_mock.py.
USE_MOCK_LLM=false

# --- Deployment / TLS (PRD Section 17) ---
APP_HOSTNAME=family.local
APP_BASE_URL=https://family.local
# CADDY_TLS=internal       -> home / LAN / Tailscale (Caddy internal CA)
# CADDY_TLS=you@email.com  -> cloud (Let's Encrypt with this contact email)
CADDY_TLS=internal

# --- Backup destination (path or S3-compatible URL) ---
BACKUP_DEST=
