# Copy to .env (or .env.home / .env.cloud) and fill in values.
# Never commit a populated .env file. .gitignore already excludes them.

# Database
DATABASE_URL=postgresql+psycopg://family_assistant:CHANGE_ME@localhost:5432/family_assistant

# Session signing — generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
SESSION_SECRET=CHANGE_ME

# Pre-seeded user credentials (PRD Section 10.1)
# Generate Argon2id hashes when the auth module exists.
USER1_EMAIL=
USER1_PASSWORD_HASH=
USER2_EMAIL=
USER2_PASSWORD_HASH=

# Ollama / LLM runtime (PRD Section 16.8)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Deployment context (PRD Section 17)
APP_HOSTNAME=family.local
APP_BASE_URL=https://family.local

# Backup destination (path or S3-compatible URL)
BACKUP_DEST=
